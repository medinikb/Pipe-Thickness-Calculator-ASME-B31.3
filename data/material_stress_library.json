  "metadata": {
    "title": "ASME B31.3-2018 private combined basic allowable stress dataset for pipe thickness web app",
    "source": "ASME B31.3-2018, Appendix A Table A-1M and Appendix B Table B-1M where applicable",
    "unit_system": "SI",
    "stress_unit": "MPa",
    "temperature_unit": "degC",
    "intended_use": "Private web app dataset for ASME B31.3 pipe wall thickness calculation. Use as licensed/internal reference only.",
    "contains_copyrighted_asme_stress_values": true,
    "public_github_warning": "Do not publish this file in a public GitHub Pages repository unless your organization has redistribution rights. Keep it private or load it from a protected source.",
    "merge_sources": [
      "b31_3_2018_stress_dataset_subset.json",
      "b31_3_2018_incremental_unique_stress_rows_list2.json"
    ],
    "material_record_count": 27,
    "incremental_unique_rows_added_count": 3,
    "incremental_unique_rows_added": [
      "A312_TP304L",
      "A333_6",
      "A671_CC60"
    ],
    "table_notes_policy": "notes contains note numbers appearing in the ASME stress table. note_summaries are abbreviated engineering reminders, not full ASME note text. Verify against the licensed code before release.",
    "schema_policy": "The main lookup collection remains materials, same as the original subset file. alias_review and implementation_rules are included for app validation and duplicate handling."
  },
